{
  "name": "lametric-yle",
  "version": "4.0.0",
  "description": "Backend for LaMetric YLE News app",
  "license": "Unlicense",
  "type": "module",
  "main": "./dist/index.js",
  "main:src": "./src/index.ts",
  "types": "./dist/index.d.ts",
  "files": [
    "./bin",
    "./dist"
  ],
  "keywords": [
    "lametric",
    "microservice",
    "news"
  ],
  "bin": {
    "lametric-yle": "./bin/lametric-yle"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "clean": "rimraf './dist'",
    "lint": "eslint './src/**/*'",
    "test": "vitest run",
    "prebuild": "$npm_execpath run clean",
    "prepack": "$npm_execpath run build"
  },
  "repository": "https://github.com/RauliL/lametric-yle.git",
  "bugs": {
    "url": "https://github.com/RauliL/lametric-yle/issues"
  },
  "homepage": "https://github.com/RauliL/lametric-yle",
  "author": "Rauli Laine <rauli.laine@iki.fi>",
  "engines": {
    "node": ">=12"
  },
  "dependencies": {
    "debug": "^4.4.3",
    "express": "^5.2.1",
    "lametric-rss-formatter": "^2.0.0",
    "normalize-port": "^1.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/express": "^5.0.6",
    "@types/supertest": "^6.0.3",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "msw": "^2.12.7",
    "nodemon": "^3.1.11",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.2",
    "supertest": "^7.2.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.53.1",
    "vitest": "^4.0.18"
  }
}
